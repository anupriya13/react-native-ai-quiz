{
  "name": "react-native-ai-quiz",
  "version": "1.0.0",
  "description": "Cross-platform React Native module that generates AI-powered quiz questions dynamically using Azure OpenAI.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "setup": "node setup-local.js",
    "test-local": "node test-local.js",
    "test-security": "node test-security.js",
    "demo": "node demo.js",
    "example": "cd example && npm install --legacy-peer-deps && npm run start",
    "example:setup": "cd example && npm install --legacy-peer-deps",
    "example:start": "cd example && npm start",
    "example:android": "cd example && npm run android",
    "example:ios": "cd example && npm run ios",
    "example:windows": "npm run example:setup && npm run example:start",
    "windows:run": "cd example && npm run windows",
    "windows:run-app": "cd example && npm run windows",
    "windows:launcher": "node windows-launcher.js",
    "example:launch-android": "cd example && npm run android",
    "windows:launch-app": "node windows-launch-app.js",
    "setup:windows": "node setup-windows.js",
    "troubleshoot": "node troubleshoot-windows.js"
  },
  "keywords": [
    "react-native",
    "ai",
    "quiz",
    "azure",
    "openai",
    "questions",
    "cross-platform"
  ],
  "author": "Anupriya Verma",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.60.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.70.0",
    "typescript": "^4.9.0"
  },
  "dependencies": {
    "axios": "^1.11.0"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anupriya13/react-native-ai-quiz.git"
  },
  "homepage": "https://github.com/anupriya13/react-native-ai-quiz#readme",
  "bugs": {
    "url": "https://github.com/anupriya13/react-native-ai-quiz/issues"
  }
}
